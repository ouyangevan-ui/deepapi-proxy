[Unit]
Description=DeepAPI encrypted offsite backup
Documentation=./RESTORE-DRILL-RUNBOOK.md
Wants=network-online.target
After=network-online.target docker.service

[Service]
Type=oneshot
User=root
Group=root
ExecStart=/usr/local/sbin/deepapi-backup-job
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=read-only
ProtectSystem=full
