# DeepAPI backup job configuration example.
# Copy to /etc/deepapi/backup.env, then set owner root:root and mode 0600.
# Do not commit live paths that reveal infrastructure, private keys, webhook URLs, or secrets.

DB_PATH=/opt/one-api/data/one-api.db

# Must be a separately mounted offsite filesystem. A local tarball or same-disk
# directory is NO-GO for production.
BACKUP_OFFSITE_DIR=/mnt/deepapi-offsite

# Working directory for SQLite snapshots and temporary archives. The backup
# script creates per-run 0700 subdirectories below this path.
BACKUP_LOCAL_TMP=/var/tmp/deepapi-backup

# Root-owned regular file containing age public recipients, one per line.
# Keep private age identities out of Git, chat, screenshots, and logs.
AGE_RECIPIENTS_FILE=/etc/deepapi/age-recipients.txt

BACKUP_RETENTION_DAYS=30
